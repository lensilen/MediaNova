{
  "expo": {
    "name": "MediaNova",
    "slug": "medianova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medianova",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.kelompok3.medianova",
      "adaptiveIcon": {
        "backgroundColor": "#F5EFEB",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VIDEO",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#2F4156",
          "image": "./assets/images/icon_splash.png",
          "imageWidth": 240,
          "resizeMode": "contain"
        }
      ],
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "MediaNova membutuhkan kamera untuk membuat foto dan video.",
          "microphonePermission": "MediaNova membutuhkan mikrofon untuk merekam video dan audio."
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "MediaNova membutuhkan galeri untuk memilih media."
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a1e08572-b69b-4f47-aeb4-c8d6717cc9b6"
      }
    },
    "owner": "lensilen"
  }
}
