{
  "expo": {
    "name": "MediaNova",
    "slug": "medianova",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "medianova",
    "userInterfaceStyle": "automatic",
    "android": {
      "package": "com.kelompok3.medianova",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-dev-client",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-video",
      [
        "expo-camera",
        {
          "cameraPermission": "MediaNova membutuhkan kamera untuk membuat foto dan video.",
          "microphonePermission": "MediaNova membutuhkan mikrofon untuk merekam video dan audio."
        }
      ],
      "expo-audio",
      [
        "expo-image-picker",
        {
          "photosPermission": "MediaNova membutuhkan galeri untuk memilih media."
        }
      ],
      "expo-web-browser",
      "expo-notifications",
      "expo-font",
      "expo-asset"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "cf34ce6d-57b1-434a-8d80-581c56223c21"
      }
    }
  }
}
