rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    function postCounterUpdateOnly() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let likesValid =
        !changedKeys.hasAny(['likes']) ||
        request.resource.data.likes >= 0 &&
        (
          request.resource.data.likes == resource.data.likes + 1 ||
          request.resource.data.likes == resource.data.likes - 1 ||
          request.resource.data.likes == resource.data.likes
        );
      let commentsValid =
        !changedKeys.hasAny(['commentsCount']) ||
        request.resource.data.commentsCount >= 0 &&
        (
          request.resource.data.commentsCount == resource.data.commentsCount + 1 ||
          request.resource.data.commentsCount == resource.data.commentsCount
        );

      return signedIn() &&
        changedKeys.hasOnly(['likes', 'commentsCount', 'updatedAt']) &&
        likesValid &&
        commentsValid;
    }

    function userCounterUpdateOnly() {
      let changedKeys = request.resource.data.diff(resource.data).affectedKeys();
      let followersValid =
        !changedKeys.hasAny(['followers']) ||
        request.resource.data.followers >= 0 &&
        (
          request.resource.data.followers == resource.data.followers + 1 ||
          request.resource.data.followers == resource.data.followers - 1 ||
          request.resource.data.followers == resource.data.followers
        );
      let followingValid =
        !changedKeys.hasAny(['following']) ||
        request.resource.data.following >= 0 &&
        (
          request.resource.data.following == resource.data.following + 1 ||
          request.resource.data.following == resource.data.following - 1 ||
          request.resource.data.following == resource.data.following
        );

      return signedIn() &&
        changedKeys.hasOnly(['followers', 'following', 'updatedAt']) &&
        followersValid &&
        followingValid;
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || userCounterUpdateOnly();
      allow delete: if isOwner(userId);
    }

    match /posts/{postId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if (signedIn() && resource.data.userId == request.auth.uid) || postCounterUpdateOnly();
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /comments/{commentId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if signedIn() && resource.data.userId == request.auth.uid;
    }

    match /likes/{likeId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /saves/{saveId} {
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if signedIn() && resource.data.userId == request.auth.uid;
      allow update: if false;
    }

    match /follows/{followId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.resource.data.followerId == request.auth.uid;
      allow delete: if signedIn() && resource.data.followerId == request.auth.uid;
      allow update: if false;
    }

    match /notifications/{notificationId} {
      allow read, update: if signedIn() && resource.data.toUserId == request.auth.uid;
      allow create: if signedIn() && request.resource.data.fromUserId == request.auth.uid;
      allow delete: if false;
    }
  }
}
